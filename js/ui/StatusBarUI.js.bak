/**
 * 状态栏组件类
 * 状态栏的具体实现，继承自UIElementBase
 */
class StatusBarUI extends UIElementBase {
    /**
     * 构造函数
     * @param {Object} config 状态栏配置
     * @param {Object} config.shadow 阴影配置
     * @param {string} config.image 图片路径
     * @param {string} config.text 文本内容
     */
    constructor(config) {
        super(config);
        
        // 状态栏特定默认配置
        this.defaultStatusBarConfig = {
            basePosition: { x: 280, y: 20 },
            baseSize: { width: 2000, height: 200 },
            shadow: {
                offsetX: 4,
                offsetY: 4,
                color: 'rgba(0, 0, 0, 0.5)',
                opacity: 0.7
            },
            image: 'assets/statusbar/default.png',
            text: '',
            borderColor: 'transparent',
            borderWidth: 0,
            borderRadius: 0,
            zIndex: 100
        };
        
        // 合并配置
        this.config = { ...this.defaultStatusBarConfig, ...this.config };
        
        this.imageElement = null;
        this.textElement = null;
    }
    
    /**
     * 渲染状态栏
     */
    render() {
        // 创建容器
        const container = this.createContainer();
        container.className = 'status-bar-container';
        this.domElement = container;
        
        // 创建主层
        const mainLayer = document.createElement('div');
        mainLayer.className = 'status-bar-main';
        mainLayer.id = this.id + 'Main';
        
        // 创建图片元素（如果有图片）
        if (this.config.image) {
            this.imageElement = document.createElement('img');
            this.imageElement.className = 'status-bar-image';
            this.imageElement.src = this.config.image;
            this.imageElement.alt = '状态栏';
            this.imageElement.style.width = '100%';
            this.imageElement.style.height = '100%';
            this.imageElement.style.objectFit = 'cover';
            mainLayer.appendChild(this.imageElement);
        }
        
        // 创建文本元素（如果有文本）
        if (this.config.text) {
            this.textElement = document.createElement('div');
            this.textElement.className = 'status-bar-text';
            this.textElement.textContent = this.config.text;
            this.textElement.style.position = 'absolute';
            this.textElement.style.top = '50%';
            this.textElement.style.left = '50%';
            this.textElement.style.transform = 'translate(-50%, -50%)';
            this.textElement.style.color = 'white';
            this.textElement.style.fontSize = '24px';
            this.textElement.style.fontWeight = 'bold';
            this.textElement.style.textShadow = '2px 2px 4px rgba(0,0,0,0.5)';
            mainLayer.appendChild(this.textElement);
        }
        
        // 应用边框样式
        mainLayer.style.border = `${this.config.borderWidth}px solid ${this.config.borderColor}`;
        mainLayer.style.borderRadius = `${this.config.borderRadius}px`;
        mainLayer.style.overflow = 'hidden';
        
        container.appendChild(mainLayer);
        
        // 将容器添加到body
        document.body.appendChild(container);
        
        // 应用缩放
        this.applyScale();
        
        // 应用阴影
        if (this.config.shadow) {
            this.applyShadow(this.config.shadow);
        }
        
        // 从本地存储加载保存的配置
        this.loadConfig();
    }
    
    /**
     * 更新图片
     * @param {string} imageSrc 图片路径或data URL
     */
    updateImage(imageSrc) {
        this.config.image = imageSrc;
        
        if (imageSrc) {
            // 如果已有图片元素，更新src
            if (this.imageElement) {
                this.imageElement.src = imageSrc;
            } else {
                // 创建新的图片元素
                this.imageElement = document.createElement('img');
                this.imageElement.className = 'status-bar-image';
                this.imageElement.src = imageSrc;
                this.imageElement.alt = '状态栏';
                this.imageElement.style.width = '100%';
                this.imageElement.style.height = '100%';
                this.imageElement.style.objectFit = 'cover';
                
                // 添加到主层
                const mainLayer = this.domElement.querySelector('.status-bar-main');
                if (mainLayer) {
                    // 移除文本元素（如果有）
                    if (this.textElement && this.textElement.parentNode) {
                        mainLayer.removeChild(this.textElement);
                        this.textElement = null;
                    }
                    mainLayer.appendChild(this.imageElement);
                }
            }
            
            // 清空文本
            this.config.text = '';
        } else {
            // 移除图片元素
            if (this.imageElement && this.imageElement.parentNode) {
                this.imageElement.parentNode.removeChild(this.imageElement);
                this.imageElement = null;
            }
        }
        
        this.saveConfig();
    }
    
    /**
     * 更新文本
     * @param {string} text 文本内容
     */
    updateText(text) {
        this.config.text = text;
        
        if (text) {
            // 如果已有文本元素，更新内容
            if (this.textElement) {
                this.textElement.textContent = text;
            } else {
                // 创建新的文本元素
                this.textElement = document.createElement('div');
                this.textElement.className = 'status-bar-text';
                this.textElement.textContent = text;
                this.textElement.style.position = 'absolute';
                this.textElement.style.top = '50%';
                this.textElement.style.left = '50%';
                this.textElement.style.transform = 'translate(-50%, -50%)';
                this.textElement.style.color = 'white';
                this.textElement.style.fontSize = '24px';
                this.textElement.style.fontWeight = 'bold';
                this.textElement.style.textShadow = '2px 2px 4px rgba(0,0,0,0.5)';
                
                // 添加到主层
                const mainLayer = this.domElement.querySelector('.status-bar-main');
                if (mainLayer) {
                    // 移除图片元素（如果有）
                    if (this.imageElement && this.imageElement.parentNode) {
                        mainLayer.removeChild(this.imageElement);
                        this.imageElement = null;
                    }
                    mainLayer.appendChild(this.textElement);
                }
            }
            
            // 清空图片
            this.config.image = '';
        } else {
            // 移除文本元素
            if (this.textElement && this.textElement.parentNode) {
                this.textElement.parentNode.removeChild(this.textElement);
                this.textElement = null;
            }
        }
        
        this.saveConfig();
    }
    
    /**
     * 更新阴影配置
     * @param {number} offsetX X轴偏移
     * @param {number} offsetY Y轴偏移
     * @param {string} color 阴影颜色
     * @param {number} opacity 阴影透明度
     */
    updateShadow(offsetX, offsetY, color, opacity = 0.7) {
        this.setShadow(offsetX, offsetY, color, opacity);
    }
    
    /**
     * 应用图片
     * @param {string} src 图片路径
     */
    applyImage(src) {
        this.updateImage(src);
    }
    
    /**
     * 设置边框
     * @param {string} color 边框颜色
     * @param {number} width 边框宽度
     * @param {number} radius 圆角半径
     */
    setBorder(color, width, radius) {
        this.config.borderColor = color;
        this.config.borderWidth = width;
        this.config.borderRadius = radius;
        
        const mainLayer = this.domElement.querySelector('.status-bar-main');
        if (mainLayer) {
            mainLayer.style.border = `${width}px solid ${color}`;
            mainLayer.style.borderRadius = `${radius}px`;
        }
        
        this.saveConfig();
    }
    
    /**
     * 获取状态栏信息
     * @returns {Object} 状态栏信息
     */
    getInfo() {
        const actualPosition = this.getActualPosition();
        const actualSize = this.getActualSize();
        
        return {
            id: this.id,
            type: this.type,
            basePosition: this.config.basePosition,
            baseSize: this.config.baseSize,
            actualPosition,
            actualSize,
            shadow: this.config.shadow,
            hasImage: !!this.config.image,
            hasText: !!this.config.text,
            visible: this.config.visible,
            zIndex: this.config.zIndex
        };
    }
    
    /**
     * 导出配置
     * @returns {Object} 状态栏配置
     */
    exportConfig() {
        return {
            ...this.config,
            id: this.id,
            type: this.type
        };
    }
    
    /**
     * 导入配置
     * @param {Object} config 配置对象
     */
    importConfig(config) {
        // 保留id和type
        const { id, type, ...restConfig } = config;
        this.config = { ...this.config, ...restConfig };
        
        // 重新渲染
        this.applyScale();
        if (this.config.shadow) {
            this.applyShadow(this.config.shadow);
        }
        
        // 更新图片或文本
        if (this.config.image) {
            this.updateImage(this.config.image);
        } else if (this.config.text) {
            this.updateText(this.config.text);
        }
        
        // 更新边框
        const mainLayer = this.domElement.querySelector('.status-bar-main');
        if (mainLayer) {
            mainLayer.style.border = `${this.config.borderWidth}px solid ${this.config.borderColor}`;
            mainLayer.style.borderRadius = `${this.config.borderRadius}px`;
        }
        
        this.saveConfig();
    }
    
    /**
     * 重置为默认配置
     */
    resetToDefault() {
        this.config = { ...this.defaultStatusBarConfig };
        this.applyScale();
        if (this.config.shadow) {
            this.applyShadow(this.config.shadow);
        }
        
        // 重置图片
        if (this.config.image) {
            this.updateImage(this.config.image);
        }
        
        // 重置边框
        const mainLayer = this.domElement.querySelector('.status-bar-main');
        if (mainLayer) {
            mainLayer.style.border = `${this.config.borderWidth}px solid ${this.config.borderColor}`;
            mainLayer.style.borderRadius = `${this.config.borderRadius}px`;
        }
        
        this.saveConfig();
    }
    
    /**
     * 添加点击事件监听器
     * @param {Function} callback 点击回调函数
     */
    onClick(callback) {
        if (this.domElement) {
            this.domElement.addEventListener('click', callback);
        }
    }
    
    /**
     * 移除点击事件监听器
     * @param {Function} callback 点击回调函数
     */
    removeClick(callback) {
        if (this.domElement) {
            this.domElement.removeEventListener('click', callback);
        }
    }
}

// 导出StatusBarUI类
if (typeof module !== 'undefined' && module.exports) {
    module.exports = StatusBarUI;
}